<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-5">
      <h1 class="text-center">Modelos de Cestas</h1>
      <p class="text-center lead">Cadastre um novo modelo de cesta</p>

      <%- include('includes/messages') %>

        <form action="/cadastrar/cestaPadrao" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
            <label>Nome da Cesta</label>
            <input type="text" class="form-control" name="nome">
        </div>

        <div class="form-group">
            <label>Produto</label> <br>
            <select name="opcoes" class="produtos1">
                <% produtos.forEach( produto => { %>
                    <option value="produto"> <%= produto.nome %> </option>
                <% }) %>
            </select>
            qtd: <input type="number" name="quantidade" class="qtdInput">
        </div>

        <div class="form-group">
            <label>Produto</label> <br>
            <select name="opcoes" class="produtos1">
                <% produtos.forEach( produto => { %>
                    <option value="produto"> <%= produto.nome %> </option>
                <% }) %>
            </select>
            qtd: <input type="number" name="quantidade" class="qtdInput">            
        </div>
        
        <template id="templateSelect">
        <div class="form-group">
            <label>Produto</label> <br>
            <select name="opcoes" class="produtos1">
                <% produtos.forEach( produto => { %>
                    <option value="produto"> <%= produto.nome %> </option>
                <% }) %>
            </select>
            qtd: <input type="number" name="quantidade" class="qtdInput"> <br> 
        </div>
        </template>

        <div class="maisProdutos"></div> <br>

        <strong class="btn btn-primary" id="addCampo"> Produto +</strong> <br> <br>

        <button type="submit" class="btn btn-success">Cadastrar Cesta</button>
      </form>   

    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('includes/footer')%>
